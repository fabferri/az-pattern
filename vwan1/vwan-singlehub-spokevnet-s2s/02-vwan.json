{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "hub1location": {
            "type": "string",
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "Location where all resources will be created."
            }
        },
        "vwanName": {
            "type": "string",
            "defaultValue": "vwan1",
            "metadata": {
                "description": "Name of the Virtual Wan."
            }
        },
        "vwanSKU": {
            "type": "string",
            "defaultValue": "Standard",
            "metadata": {
                "description": "Sku of the Virtual Wan."
            },
            "allowedValues": [
                "Standard",
                "Basic"
            ]
        },
        "hub1Name": {
            "type": "string",
            "defaultValue": "hub90",
            "metadata": {
                "description": "Name of the Virtual Hub. A virtual hub is created inside a virtual wan."
            }
        },
        "rgSpoke21": {
            "type": "string",
            "defaultValue": "spoke21",
            "metadata": {
                "description": "Location where all resources will be created."
            }
        },
        "rgSpoke22": {
            "type": "string",
            "defaultValue": "spoke22",
            "metadata": {
                "description": "Location where all resources will be created."
            }
        },
        "hub1_S2SvpnGatewayScaleUnit": {
            "type": "int",
            "defaultValue": 1,
            "metadata": {
                "description": "Scale Units for Site-to-Site (S2S) VPN Gateway in the hub1"
            }
        },
        "deployVPNGtwS2S": {
            "type": "bool",
            "defaultValue": true,
            "metadata": {
                "description": "boolean flag to deploy the Site-to-Site (S2S) VPN Gateway in the hub1"
            }
        },
        "hub1vpnGwName": {
            "type": "string",
            "defaultValue": "gw1",
            "metadata": {
                "description": "Name of the VPN Gateway in the hub1."
            }
        },
        "spoke21vnetName": {
            "type": "string",
            "defaultValue": "spoke21"
        },
        "spoke21AddressPrefix": {
            "type": "string",
            "defaultValue": "10.21.0.0/24"
        },
        "spoke21subnetFEName": {
            "type": "string",
            "defaultValue": "subnetFE"
        },
        "spoke21subnetFEPrefix": {
            "type": "string",
            "defaultValue": "10.21.0.0/28"
        },
        "spoke21subnetBEName": {
            "type": "string",
            "defaultValue": "subnetBE"
        },
        "spoke21subnetBEPrefix": {
            "type": "string",
            "defaultValue": "10.21.0.16/28"
        },
        "spoke21subnetWLName": {
            "type": "string",
            "defaultValue": "subnetWL"
        },
        "spoke21subnetWLPrefix": {
            "type": "string",
            "defaultValue": "10.21.0.32/28"
        },
        "spoke21BAddressPrefix": {
            "type": "string",
            "defaultValue": "10.21.1.0/24"
        },
        "spoke21lbFrontEndIP": {
            "type": "string",
            "defaultValue": "10.21.0.10"
        },
        "spoke22vnetName": {
            "type": "string",
            "defaultValue": "spoke22"
        },
        "spoke22AddressPrefix": {
            "type": "string",
            "defaultValue": "10.22.0.0/24"
        },
        "spoke22subnetFEName": {
            "type": "string",
            "defaultValue": "subnetFE"
        },
        "spoke22subnetFEPrefix": {
            "type": "string",
            "defaultValue": "10.22.0.0/28"
        },
        "spoke22subnetBEName": {
            "type": "string",
            "defaultValue": "subnetBE"
        },
        "spoke22subnetBEPrefix": {
            "type": "string",
            "defaultValue": "10.22.0.16/28"
        },
        "spoke22subnetWLName": {
            "type": "string",
            "defaultValue": "subnetWL"
        },
        "spoke22subnetWLPrefix": {
            "type": "string",
            "defaultValue": "10.22.0.32/28"
        },
        "spoke22BAddressPrefix": {
            "type": "string",
            "defaultValue": "10.22.1.0/24"
        },
        "spoke22lbFrontEndIP": {
            "type": "string",
            "defaultValue": "10.22.0.10"
        },
        "hub1addressPrefix":{
            "type": "string",
            "defaultValue": "10.90.0.0/23"
        }
    },
    "variables": {

        "vwanName": "[parameters('vwanName')]",
        "hub1Name": "[parameters('hub1Name')]",
        "hub1location": "[parameters('hub1location')]",
        "hub1addressPrefix": "[parameters('hub1addressPrefix')]",

        "spoke1vnetName": "[parameters('spoke21vnetName')]",
        "spoke2vnetName": "[parameters('spoke22vnetName')]",

        "spoke21BPrefix": "[parameters('spoke21BAddressPrefix')]",
        "spoke22BPrefix": "[parameters('spoke22BAddressPrefix')]",

        "spoke1vnet": {
            "location": "[variables('hub1location')]",
            "name": "[variables('spoke1vnetName')]",
            "addressPrefix1": "[parameters('spoke21AddressPrefix')]",
            "subnetFEName": "[parameters('spoke21subnetFEName')]",
            "subnetFEPrefix": "[parameters('spoke21subnetFEPrefix')]",
            "subnetBEName": "[parameters('spoke21subnetBEName')]",
            "subnetBEPrefix": "[parameters('spoke21subnetBEPrefix')]",
            "subnetWLName": "[parameters('spoke21subnetWLName')]",
            "subnetWLPrefix": "[parameters('spoke21subnetWLPrefix')]",
            "lbFrontEndIP": "[parameters('spoke21lbFrontEndIP')]"
        },
        "spoke2vnet": {
            "location": "[variables('hub1location')]",
            "name": "[variables('spoke2vnetName')]",
            "addressPrefix1": "[parameters('spoke22AddressPrefix')]",
            "subnetFEName": "[parameters('spoke22subnetFEName')]",
            "subnetFEPrefix": "[parameters('spoke22subnetFEPrefix')]",
            "subnetBEName": "[parameters('spoke22subnetBEName')]",
            "subnetBEPrefix": "[parameters('spoke22subnetBEPrefix')]",
            "subnetWLName": "[parameters('spoke22subnetWLName')]",
            "subnetWLPrefix": "[parameters('spoke22subnetWLPrefix')]",
            "lbFrontEndIP": "[parameters('spoke22lbFrontEndIP')]"
        },

        "hub1connectionNamespoke1": "[concat(variables('spoke1vnetName'),'-conn')]",
        "hub1connectionNamespoke2": "[concat(variables('spoke2vnetName'),'-conn')]",
        "vpnGwName": "[parameters('hub1vpnGwName')]"

    },
    "resources": [
        {
            "type": "Microsoft.Network/virtualWans",
            "name": "[variables('vwanName')]",
            "apiVersion": "2024-05-01",
            "location": "[variables('hub1location')]",
            "properties": {
                "type": "[parameters('vwanSKU')]"
            }
        },
        {
            "type": "Microsoft.Network/virtualHubs",
            "name": "[variables('hub1Name')]",
            "apiVersion": "2024-05-01",
            "location": "[variables('hub1location')]",
            "dependsOn": [
                "[resourceId('Microsoft.Network/virtualWans', variables('vwanName'))]"
            ],
            "properties": {
                "addressPrefix": "[variables('hub1addressPrefix')]",
                "virtualWan": {
                    "id": "[resourceId('Microsoft.Network/virtualWans',variables('vwanName'))]"
                }
            }
        },
        {
            "type": "Microsoft.Network/virtualHubs/hubRouteTables",
            "apiVersion": "2024-05-01",
            "name": "[concat(variables('hub1Name'), '/', 'defaultRouteTable')]",
            "dependsOn": [
                "[resourceId('Microsoft.Network/virtualHubs', variables('hub1Name'))]"
            ],
            "properties": {
                "labels": [ "default" ]
            }
        },
        {
            "type": "Microsoft.Network/virtualHubs/hubRouteTables",
            "apiVersion": "2024-05-01",
            "name": "[concat(variables('hub1Name'), '/', 'RT_SHARED')]",
            "dependsOn": [
                "[resourceId('Microsoft.Network/virtualHubs', variables('hub1Name'))]"
            ],
            "properties": {
                "labels": []
            }
        },
        {
            "type": "Microsoft.Network/virtualHubs/hubRouteTables",
            "apiVersion": "2024-05-01",
            "name": "[concat(variables('hub1Name'), '/', 'RT_SPOKE')]",
            "dependsOn": [
                "[resourceId('Microsoft.Network/virtualHubs', variables('hub1Name'))]"
            ],
            "properties": {
                "labels": []
            }
        },
        {
            "type": "Microsoft.Network/virtualHubs/hubVirtualNetworkConnections",
            "apiVersion": "2024-05-01",
            "name": "[format('{0}/{1}', variables('hub1Name'), variables('hub1connectionNamespoke1'))]",
            "dependsOn": [
                "[resourceId('Microsoft.Network/virtualHubs/hubRouteTables', variables('hub1Name'), 'defaultRouteTable')]"
            ],
            "properties": {
                "routingConfiguration": {
                    "associatedRouteTable": {
                        "id": "[resourceId('Microsoft.Network/virtualHubs/hubRouteTables', variables('hub1Name'), 'defaultRouteTable')]"
                    },
                    "propagatedRouteTables": {
                        "ids": [
                            {
                                "id": "[resourceId('Microsoft.Network/virtualHubs/hubRouteTables', variables('hub1Name'), 'defaultRouteTable')]"
                            }
                        ],
                        "labels": [ "default" ]
                    },
                    "vnetRoutes": {
                        "staticRoutes": [
                            {
                                "name": "to-spoke21-via-lb",
                                "addressPrefixes": [
                                    "[variables('spoke1vnet').addressPrefix1]"
                                ],
                                "nextHopIpAddress": "[variables('spoke1vnet').lbFrontEndIP]"
                            },
                            {
                                "name": "to-spoke21B-via-lb",
                                "addressPrefixes": [
                                    "[variables('spoke21BPrefix')]"
                                ],
                                "nextHopIpAddress": "[variables('spoke1vnet').lbFrontEndIP]"
                            }
                        ],
                        "staticRoutesConfig": {
                            "vnetLocalRouteOverrideCriteria": "Equal"
                        }
                    }
                },
                "remoteVirtualNetwork": {
                    "id": "[resourceId(parameters('rgSpoke21'), 'Microsoft.Network/virtualNetworks', variables('spoke1vnet').name)]"
                },
                "enableInternetSecurity": false
            }
        },
        {
            "type": "Microsoft.Network/virtualHubs/hubVirtualNetworkConnections",
            "apiVersion": "2022-05-01",
            "name": "[format('{0}/{1}', variables('hub1Name'), variables('hub1connectionNamespoke2'))]",
            "dependsOn": [
                "[resourceId('Microsoft.Network/virtualHubs/hubRouteTables', variables('hub1Name'), 'defaultRouteTable')]",
                "[resourceId('Microsoft.Network/virtualHubs/hubVirtualNetworkConnections', variables('hub1Name'), variables('hub1connectionNamespoke1'))]"
            ],
            "properties": {
                "routingConfiguration": {
                    "associatedRouteTable": {
                        "id": "[resourceId('Microsoft.Network/virtualHubs/hubRouteTables', variables('hub1Name'), 'defaultRouteTable')]"
                    },
                    "propagatedRouteTables": {
                        "ids": [
                            {
                                "id": "[resourceId('Microsoft.Network/virtualHubs/hubRouteTables', variables('hub1Name'), 'defaultRouteTable')]"
                            }
                        ],
                        "labels": [ "default" ]
                    },
                    "vnetRoutes": {
                        "staticRoutes": [
                            {
                                "name": "to-spoke22-via-lb",
                                "addressPrefixes": [
                                    "[variables('spoke2vnet').addressPrefix1]"
                                ],
                                "nextHopIpAddress": "[variables('spoke2vnet').lbFrontEndIP]"
                            },
                            {
                                "name": "to-spoke22B-via-lb",
                                "addressPrefixes": [
                                    "[variables('spoke22BPrefix')]"
                                ],
                                "nextHopIpAddress": "[variables('spoke2vnet').lbFrontEndIP]"
                            }
                        ],
                        "staticRoutesConfig": {
                            "vnetLocalRouteOverrideCriteria": "Equal"
                        }
                    }
                },
                "remoteVirtualNetwork": {
                    "id": "[resourceId(parameters('rgSpoke22'), 'Microsoft.Network/virtualNetworks', variables('spoke2vnet').name)]"
                },
                "enableInternetSecurity": false
            }
        },
        {
            "comments": "deploy of the VPN Gateway only if it does not exist",
            "condition": "[parameters('deployVPNGtwS2S') ]",
            "type": "Microsoft.Network/vpnGateways",
            "name": "[variables('vpnGwName')]",
            "apiVersion": "2024-05-01",
            "location": "[variables('hub1location')]",
            "dependsOn": [
                "[resourceId('Microsoft.Network/virtualHubs', variables('hub1Name'))]",
                "[resourceId('Microsoft.Network/virtualHubs/hubVirtualNetworkConnections', variables('hub1Name'), variables('hub1connectionNamespoke2'))]"
            ],
            "properties": {
                "vpnGatewayScaleUnit": "[parameters('hub1_S2SvpnGatewayScaleUnit')]",
                "virtualHub": {
                    "id": "[resourceId('Microsoft.Network/virtualHubs', variables('hub1Name'))]"
                },
                "bgpSettings": {
                    "asn": 65515
                }
            }
        }
    ]
}