{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "type": "string",
            "defaultValue": "SwedenCentral",
            "metadata": {
                "description": "Location for all resources."
            }
        },
        "spoke22BvnetName": {
            "type": "string",
            "defaultValue": "spoke22B",
            "metadata": {
                "description": "Name of the spoke22B virtual network."
            }
        },
        "spoke22BAddressPrefix": {
            "type": "string",
            "defaultValue": "10.22.1.0/24",
            "metadata": {
                "description": "Address prefix for the spoke22B virtual network."
            }
        },
        "spoke22BsubnetWLName": {
            "type": "string",
            "defaultValue": "subnetWL22B",
            "metadata": {
                "description": "Name of the spoke22B workload subnet."
            }
        },
        "spoke22BsubnetWLPrefix": {
            "type": "string",
            "defaultValue": "10.22.1.0/28",
            "metadata": {
                "description": "Address prefix of the spoke22B workload subnet."
            }
        },
        "WL22B-1": {
            "type": "string",
            "defaultValue": "WL22B-1",
            "metadata": {
                "description": "Name of the workload VM in spoke22B."
            }
        },
        "WL22B_1_privIP": {
            "type": "string",
            "defaultValue": "10.22.1.4",
            "metadata": {
                "description": "Private IP address of WL22B-1."
            }
        },
        "spoke22BrtSubnetWLName": {
            "type": "string",
            "defaultValue": "RT-subnetWL22B",
            "metadata": {
                "description": "Name of the route table for spoke22B subnetWL."
            }
        },
        "spoke22BrtEntryNameMajorNet": {
            "type": "string",
            "defaultValue": "to-majorNet10",
            "metadata": {
                "description": "Name of the major network route for spoke22B."
            }
        },
        "spoke22BrtEntryNameParentSpoke": {
            "type": "string",
            "defaultValue": "to-spoke22",
            "metadata": {
                "description": "Name of the route from spoke22B to spoke22."
            }
        },
        "spoke22lbFrontEndIP": {
            "type": "string",
            "defaultValue": "10.22.0.10",
            "metadata": {
                "description": "Frontend IP of the spoke22 load balancer used as next hop."
            }
        },
        "spoke22vnetName": {
            "type": "string",
            "defaultValue": "spoke22",
            "metadata": {
                "description": "Name of the parent spoke22 virtual network."
            }
        },
        "spoke22AddressPrefix": {
            "type": "string",
            "defaultValue": "10.22.0.0/24",
            "metadata": {
                "description": "Address prefix of the parent spoke22 virtual network."
            }
        },
        "vnetpeeringName22Bto22": {
            "type": "string",
            "defaultValue": "spoke22B-to-spoke22",
            "metadata": {
                "description": "Name of the peering from spoke22B to spoke22."
            }
        },
        "vnetpeeringName22to22B": {
            "type": "string",
            "defaultValue": "spoke22-to-spoke22B",
            "metadata": {
                "description": "Name of the peering from spoke22 to spoke22B."
            }
        },
        "adminUsername": {
            "type": "string",
            "metadata": {
                "description": "Admin username for the VMs."
            }
        },
        "adminPassword": {
            "type": "securestring",
            "metadata": {
                "description": "Admin password for the VMs."
            }
        },
        "vmSize": {
            "type": "string",
            "defaultValue": "Standard_B1s",
            "metadata": {
                "description": "Size of the VMs."
            }
        },
        "rgSpoke22": {
            "type": "string",
            "defaultValue": "spoke22",
            "metadata": {
                "description": "Resource group name containing the spoke22 virtual network."
            }
        }
    },
    "variables": {
        "vnetName": "[parameters('spoke22BvnetName')]",
        "vnetAddressPrefix": "[parameters('spoke22BAddressPrefix')]",
        "subnetWLName": "[parameters('spoke22BsubnetWLName')]",
        "subnetWLPrefix": "[parameters('spoke22BsubnetWLPrefix')]",
        "WL22_1_privIP": "[parameters('WL22B_1_privIP')]",
        "rtSubnetWLName": "[parameters('spoke22BrtSubnetWLName')]",
        "lbFrontEndIP": "[parameters('spoke22lbFrontEndIP')]",
        "spoke22Name": "[parameters('spoke22vnetName')]",
        "spoke22AddressPrefix": "[parameters('spoke22AddressPrefix')]",
        "spoke22ResourceGroup": "[parameters('rgSpoke22')]",
        "vnetpeeringName22Bto22": "[parameters('vnetpeeringName22Bto22')]",
        "vnetpeeringName22to22B": "[parameters('vnetpeeringName22to22B')]",

        "linux_nginx_install": "sleep 10 && sudo apt -y update && apt -y install nginx && systemctl enable nginx && systemctl start nginx",
        "linux_custompage1": "echo '<style> h1 { color: blue; } </style> <h1>' > /var/www/html/index.nginx-debian.html",
        "linux_custompage2": "cat /etc/hostname >> /var/www/html/index.nginx-debian.html",
        "linux_custompage3": "echo ' </h1>' >> /var/www/html/index.nginx-debian.html",
        "linux_nginx": "[concat(variables('linux_nginx_install'),' && ', variables('linux_custompage1'),' && ', variables('linux_custompage2'),' && ', variables('linux_custompage3'))]",
        "linuxIPForwarding": "sed -i -e '$a\\net.ipv4.ip_forward = 1' /etc/sysctl.conf && sysctl -p ",
        "linuxNVACommand": "[concat('sleep 1m', ' && ', variables('linuxIPForwarding'), ' && ', variables('linux_nginx')  )]",
        "vmArray": [
            {
                "vmName": "[parameters('WL22B-1')]",
                "subnetName": "[variables('subnetWLName')]",
                "privIP": "[variables('WL22_1_privIP')]",
                "pubIPName": "[concat(parameters('WL22B-1'),'-pubIP')]",
                "nsgName": "[concat(parameters('WL22B-1'),'-nsg')]",
                "ipforwarding": false,
                "publisher": "canonical",
                "offer": "ubuntu-24_04-lts",
                "sku": "server",
                "version": "latest",
                "commandToExecute": "[variables('linux_nginx')]"
            }
        ],
        "vmCount": "[length(variables('vmArray'))]"
    },
    "resources": [
        {
            "type": "Microsoft.Network/routeTables",
            "apiVersion": "2024-05-01",
            "name": "[variables('rtSubnetWLName')]",
            "location": "[parameters('location')]",
            "comments": "Route table: route traffic from spoke22B to spoke22 via LB frontend IP",
            "properties": {
                "routes": [
                    {
                        "name": "[parameters('spoke22BrtEntryNameMajorNet')]",
                        "properties": {
                            "addressPrefix": "10.0.0.0/8",
                            "nextHopType": "VirtualAppliance",
                            "nextHopIpAddress": "[variables('lbFrontEndIP')]"
                        }
                    },
                    {
                        "name": "[parameters('spoke22BrtEntryNameParentSpoke')]",
                        "properties": {
                            "addressPrefix": "[variables('spoke22AddressPrefix')]",
                            "nextHopType": "VirtualAppliance",
                            "nextHopIpAddress": "[variables('lbFrontEndIP')]"
                        }
                    }
                ]
            }
        },
        {
            "type": "Microsoft.Network/virtualNetworks",
            "apiVersion": "2024-05-01",
            "name": "[variables('vnetName')]",
            "location": "[parameters('location')]",
            "comments": "spoke22B VNet with one subnet (subnetWL22B) and peering to spoke22",
            "dependsOn": [
                "[resourceId('Microsoft.Network/routeTables', variables('rtSubnetWLName'))]"
            ],
            "properties": {
                "addressSpace": {
                    "addressPrefixes": [
                        "[variables('vnetAddressPrefix')]"
                    ]
                },
                "subnets": [
                    {
                        "name": "[variables('subnetWLName')]",
                        "properties": {
                            "addressPrefix": "[variables('subnetWLPrefix')]",
                            "routeTable": {
                                "id": "[resourceId('Microsoft.Network/routeTables', variables('rtSubnetWLName'))]"
                            }
                        }
                    }
                ]
            }
        },
        {
            "type": "Microsoft.Network/virtualNetworks/virtualNetworkPeerings",
            "name": "[concat(variables('vnetName'), '/', variables('vnetpeeringName22Bto22'))]",
            "apiVersion": "2024-05-01",
            "location": "[parameters('location')]",
            "comments": "VNet peering from spoke22B to spoke22",
            "dependsOn": [
                "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
            ],
            "properties": {
                "allowVirtualNetworkAccess": true,
                "allowForwardedTraffic": true,
                "allowGatewayTransit": false,
                "useRemoteGateways": false,
                "remoteVirtualNetwork": {
                    "id": "[resourceId(variables('spoke22ResourceGroup'), 'Microsoft.Network/virtualNetworks', variables('spoke22Name'))]"
                }
            }
        },
        {
            "type": "Microsoft.Resources/deployments",
            "apiVersion": "2021-04-01",
            "name": "peeringDeploymentToSpoke22",
            "resourceGroup": "[variables('spoke22ResourceGroup')]",
            "dependsOn": [
                "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
            ],
            "properties": {
                "mode": "Incremental",
                "expressionEvaluationOptions": {
                    "scope": "inner"
                },
                "parameters": {
                    "sourceVnetName": {
                        "value": "[variables('vnetName')]"
                    },
                    "sourceVnetResourceGroup": {
                        "value": "[resourceGroup().name]"
                    },
                    "targetVnetName": {
                        "value": "[variables('spoke22Name')]"
                    },
                    "targetPeeringName": {
                        "value": "[variables('vnetpeeringName22to22B')]"
                    }
                },
                "template": {
                    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
                    "contentVersion": "1.0.0.0",
                    "parameters": {
                        "sourceVnetName": {
                            "type": "string"
                        },
                        "sourceVnetResourceGroup": {
                            "type": "string"
                        },
                        "targetVnetName": {
                            "type": "string"
                        },
                        "targetPeeringName": {
                            "type": "string"
                        }
                    },
                    "variables": {},
                    "resources": [
                        {
                            "type": "Microsoft.Network/virtualNetworks/virtualNetworkPeerings",
                            "apiVersion": "2024-05-01",
                            "name": "[concat(parameters('targetVnetName'),'/',parameters('targetPeeringName'))]",
                            "properties": {
                                "allowVirtualNetworkAccess": true,
                                "allowForwardedTraffic": true,
                                "allowGatewayTransit": false,
                                "useRemoteGateways": false,
                                "remoteVirtualNetwork": {
                                    "id": "[resourceId(parameters('sourceVnetResourceGroup'), 'Microsoft.Network/virtualNetworks', parameters('sourceVnetName'))]"
                                }
                            }
                        }
                    ]
                }
            }
        },
        {
            "type": "Microsoft.Network/networkSecurityGroups",
            "apiVersion": "2024-05-01",
            "name": "[variables('vmArray')[copyIndex()].nsgName]",
            "location": "[parameters('location')]",
            "copy": {
                "name": "nsgCopy",
                "count": "[variables('vmCount')]"
            },
            "properties": {
                "securityRules": [
                    {
                        "name": "SSH-rule",
                        "properties": {
                            "description": "allow SSH",
                            "protocol": "Tcp",
                            "sourcePortRange": "*",
                            "destinationPortRange": "22",
                            "sourceAddressPrefix": "*",
                            "destinationAddressPrefix": "VirtualNetwork",
                            "access": "Allow",
                            "priority": 300,
                            "direction": "Inbound"
                        }
                    }
                ]
            }
        },
        {
            "type": "Microsoft.Network/publicIPAddresses",
            "apiVersion": "2024-05-01",
            "name": "[variables('vmArray')[copyIndex()].pubIPName]",
            "location": "[parameters('location')]",
            "sku": {
                "name": "Standard",
                "tier": "Regional"
            },
            "zones": [
                "1",
                "2",
                "3"
            ],
            "copy": {
                "name": "pubIPCopy",
                "count": "[variables('vmCount')]"
            },
            "properties": {
                "publicIPAllocationMethod": "Static"
            }
        },
        {
            "type": "Microsoft.Network/networkInterfaces",
            "apiVersion": "2024-05-01",
            "name": "[concat(variables('vmArray')[copyIndex()].vmName, '-nic')]",
            "location": "[parameters('location')]",
            "copy": {
                "name": "nicCopy",
                "count": "[variables('vmCount')]"
            },
            "dependsOn": [
                "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]",
                "[resourceId('Microsoft.Network/publicIPAddresses', variables('vmArray')[copyIndex()].pubIPName)]",
                "[resourceId('Microsoft.Network/networkSecurityGroups', variables('vmArray')[copyIndex()].nsgName)]"
            ],
            "properties": {
                "ipConfigurations": [
                    {
                        "name": "ipconfig1",
                        "properties": {
                            "privateIPAllocationMethod": "Static",
                            "privateIPAddress": "[variables('vmArray')[copyIndex()].privIP]",
                            "subnet": {
                                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('vnetName'), variables('vmArray')[copyIndex()].subnetName)]"
                            },
                            "publicIPAddress": {
                                "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('vmArray')[copyIndex()].pubIPName)]"
                            }
                        }
                    }
                ],
                "networkSecurityGroup": {
                    "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('vmArray')[copyIndex()].nsgName)]"
                },
                "enableIPForwarding": "[variables('vmArray')[copyIndex()].ipforwarding]"
            }
        },
        {
            "type": "Microsoft.Compute/virtualMachines",
            "apiVersion": "2024-07-01",
            "name": "[variables('vmArray')[copyIndex()].vmName]",
            "location": "[parameters('location')]",
            "copy": {
                "name": "vmCopy",
                "count": "[variables('vmCount')]"
            },
            "dependsOn": [
                "[resourceId('Microsoft.Network/networkInterfaces', concat(variables('vmArray')[copyIndex()].vmName, '-nic'))]"
            ],
            "properties": {
                "hardwareProfile": {
                    "vmSize": "[parameters('vmSize')]"
                },
                "osProfile": {
                    "computerName": "[variables('vmArray')[copyIndex()].vmName]",
                    "adminUsername": "[parameters('adminUsername')]",
                    "adminPassword": "[parameters('adminPassword')]"
                },
                "storageProfile": {
                    "imageReference": {
                        "publisher": "canonical",
                        "offer": "0001-com-ubuntu-server-focal",
                        "sku": "20_04-lts",
                        "version": "latest"
                    },
                    "osDisk": {
                        "name": "[concat(variables('vmArray')[copyIndex()].vmName, '-osdisk')]",
                        "createOption": "FromImage",
                        "managedDisk": {
                            "storageAccountType": "Standard_LRS"
                        }
                    }
                },
                "networkProfile": {
                    "networkInterfaces": [
                        {
                            "id": "[resourceId('Microsoft.Network/networkInterfaces', concat(variables('vmArray')[copyIndex()].vmName, '-nic'))]"
                        }
                    ]
                }
            }
        },
        {
            "type": "Microsoft.Compute/virtualMachines/extensions",
            "apiVersion": "2024-07-01",
            "name": "[concat(variables('vmArray')[copyIndex()].vmName, '/installNginx')]",
            "location": "[parameters('location')]",
            "copy": {
                "name": "extCopy",
                "count": "[variables('vmCount')]"
            },
            "dependsOn": [
                "[resourceId('Microsoft.Compute/virtualMachines', variables('vmArray')[copyIndex()].vmName)]"
            ],
            "properties": {
                "publisher": "Microsoft.Azure.Extensions",
                "type": "CustomScript",
                "typeHandlerVersion": "2.1",
                "autoUpgradeMinorVersion": true,
                "settings": {
                    "commandToExecute": "[variables('vmArray')[copyIndex()].commandToExecute]"
                },
                "protectedSettings": {}
            }
        }
    ],
    "outputs": {
        "WL22B-1": {
            "type": "string",
            "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', concat(parameters('WL22B-1'), '-pubIP'))).ipAddress]"
        }
    }
}