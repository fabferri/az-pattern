{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "type": "string",
            "metadata": {
                "description": "Azure region for the spoke VNets"
            }
        },
        "spoke1": {
            "type": "string",
            "defaultValue": "spoke-1",
            "metadata": {
                "description": "Name of spoke VNet 1"
            }
        },
        "spoke2": {
            "type": "string",
            "defaultValue": "spoke-2",
            "metadata": {
                "description": "Name of spoke VNet 2"
            }
        },
        "spoke3": {
            "type": "string",
            "defaultValue": "spoke-3",
            "metadata": {
                "description": "Name of spoke VNet 3"
            }
        },
        "spoke4": {
            "type": "string",
            "defaultValue": "spoke-4",
            "metadata": {
                "description": "Name of spoke VNet 4"
            }
        },
        "spoke5": {
            "type": "string",
            "defaultValue": "spoke-5",
            "metadata": {
                "description": "Name of spoke VNet 5"
            }
        },
        "spoke6": {
            "type": "string",
            "defaultValue": "spoke-6",
            "metadata": {
                "description": "Name of spoke VNet 6"
            }
        }
    },
    "variables": {},
    "resources": [
        {
            "type": "Microsoft.Network/virtualNetworks",
            "apiVersion": "2025-07-01",
            "name": "[parameters('spoke1')]",
            "location": "[parameters('location')]",
            "properties": {
                "addressSpace": {
                    "addressPrefixes": [
                        "10.90.0.0/24",
                        "10.90.1.0/24",
                        "10.90.2.0/24",
                        "10.90.3.0/24",
                        "10.90.4.0/24",
                        "10.90.5.0/24",
                        "10.90.6.0/24",
                        "10.90.7.0/24"
                    ]
                }
            }
        },
        {
            "type": "Microsoft.Network/virtualNetworks",
            "apiVersion": "2025-07-01",
            "name": "[parameters('spoke2')]",
            "location": "[parameters('location')]",
            "properties": {
                "addressSpace": {
                    "addressPrefixes": [
                        "10.90.8.0/24",
                        "10.90.9.0/24",
                        "10.90.10.0/24",
                        "10.90.11.0/24"
                    ]
                }
            }
        },
        {
            "type": "Microsoft.Network/virtualNetworks",
            "apiVersion": "2025-07-01",
            "name": "[parameters('spoke3')]",
            "location": "[parameters('location')]",
            "properties": {
                "addressSpace": {
                    "addressPrefixes": [
                        "10.90.16.0/24",
                        "10.90.17.0/24",
                        "10.90.18.0/24",
                        "10.90.19.0/24"
                    ]
                }
            }
        },
        {
            "type": "Microsoft.Network/virtualNetworks",
            "apiVersion": "2025-07-01",
            "name": "[parameters('spoke4')]",
            "location": "[parameters('location')]",
            "properties": {
                "addressSpace": {
                    "addressPrefixes": [
                        "10.90.24.0/24",
                        "10.90.25.0/24",
                        "10.90.26.0/24",
                        "10.90.27.0/24"
                    ]
                }
            }
        },
        {
            "type": "Microsoft.Network/virtualNetworks",
            "apiVersion": "2025-07-01",
            "name": "[parameters('spoke5')]",
            "location": "[parameters('location')]",
            "properties": {
                "addressSpace": {
                    "addressPrefixes": [
                        "10.90.32.0/24",
                        "10.90.33.0/24",
                        "10.90.34.0/24",
                        "10.90.35.0/24"
                    ]
                }
            }
        },
        {
            "type": "Microsoft.Network/virtualNetworks",
            "apiVersion": "2025-07-01",
            "name": "[parameters('spoke6')]",
            "location": "[parameters('location')]",
            "properties": {
                "addressSpace": {
                    "addressPrefixes": [
                        "10.90.40.0/24",
                        "10.90.41.0/24",
                        "10.90.42.0/24",
                        "10.90.43.0/24"
                    ]
                }
            }
        }
    ]
}
