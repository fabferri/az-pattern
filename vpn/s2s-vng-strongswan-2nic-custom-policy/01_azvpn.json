{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location1": {
            "type": "string",
            "defaultValue": "uksouth",
            "metadata": {
                "description": "Azure region"
            }
        },
        "location2": {
            "type": "string",
            "defaultValue": "uksouth",
            "metadata": {
                "description": "Azure region"
            }
        },
        "vnet1Name": {
            "type": "string",
            "defaultValue": "vnet1",
            "metadata": {
                "description": "Arbitrary name for the Azure Virtual Network"
            }
        },
        "vnet2Name": {
            "type": "string",
            "defaultValue": "vnet2",
            "metadata": {
                "description": "Arbitrary name for the Azure Virtual Network"
            }
        },
        "gatewayName": {
            "type": "string",
            "defaultValue": "gw",
            "metadata": {
                "description": "Arbitrary name for the new gateway"
            }
        },
        "gatewaySku": {
            "type": "string",
            "defaultValue": "VpnGw2AZ",
            "metadata": {
                "description": "The Sku of the Gateway"
            }
        },
        "asnGtw1": {
            "type": "int",
            "defaultValue": 65010,
            "metadata": {
                "description": "BGP Autonomous System Number of the VNet"
            }
        },
        "asnGtw2": {
            "type": "int",
            "defaultValue": 65020,
            "metadata": {
                "description": "BGP Autonomous System Number of the remote VNet"
            }
        },
        "vmSize": {
            "type": "string",
            "defaultValue": "Standard_B1s",
            "metadata": {
                "description": "Size of the Virtual Machine."
            }
        },
        "nvaName": {
            "type": "string",
            "defaultValue": "nva",
            "metadata": {
                "description": "NVA name"
            }
        },
        "nvaVMSize": {
            "type": "string",
            "defaultValue": "Standard_B2s_v2",
            "metadata": {
                "description": "Size of the Virtual Machine."
            }
        },
        "adminUsername": {
            "type": "string",
            "metadata": {
                "description": "Username for sample VM"
            }
        },
        "adminPassword": {
            "type": "securestring",
            "metadata": {
                "description": "User password for sample VM"
            }
        },
        "storageAccountType": {
            "type": "string",
            "defaultValue": "Premium_LRS",
            "allowedValues": [
                "Standard_LRS",
                "Premium_LRS"
            ],
            "metadata": {
                "description": "The storage account type for the disks of the VM"
            }
        }
    },
    "variables": {
        "location1": "[parameters('location1')]",
        "location2": "[parameters('location2')]",
        "gatewayName": "[parameters('gatewayName')]",
        "vnet1Name": "[parameters('vnet1Name')]",
        "vnet2Name": "[parameters('vnet2Name')]",
        "gatewayPublicIP1Name": "[concat(variables('gatewayName'), '-pubIP1')]",
        "gatewayPublicIP2Name": "[concat(variables('gatewayName'), '-pubIP2')]",

        "asnGtw1": "[parameters('asnGtw1')]",
        "asnGtw2": "[parameters('asnGtw2')]",

        "vnet1": {
            "location": "[variables('location1')]",
            "name": "[variables('vnet1Name')]",
            "addressSpace": "10.1.0.0/24",
            "GatewaySubnet": "GatewaySubnet",
            "GatewaySubnetPrefix": "10.1.0.0/26",
            "subnetApp": "subnetApp",
            "subnetAppPrefix": "10.1.0.64/26"
        },
        "vnet2": {
            "location": "[variables('location2')]",
            "name": "[variables('vnet2Name')]",
            "addressSpace": "10.2.0.0/24",
            "subnetNvaExternal": "nvaExternalSubnet",
            "subnetNvaExternalPrefix": "10.2.0.0/27",
            "subnetNvaInternal": "nvaInternalSubnet",
            "subnetNvaInternalPrefix": "10.2.0.32/27",
            "subnetApp": "subnetApp",
            "subnetAppPrefix": "10.2.0.64/27"
        },
        "nvaName": "[parameters('nvaName')]",
        "nvaExternalPrivIP": "10.2.0.10",
        "nvaInternalPrivIP": "10.2.0.40",
        "nvaVMSize": "[parameters('nvaVMSize')]",
        "RTnva": "RT-to-nva",
        "nsgNvaExternal": "nsg-nva-external",
        "nsgNvaInternal": "nsg-nva-internal",
        "nsgSubnet": "nsg-vnet2-subnets",
        "linuxUpdate": "sudo apt update; ",
        "linuxNgixCommand": "[concat('sudo apt-get -y install nginx; sudo systemctl enable nginx; sudo systemctl start nginx; echo \"<style> h1 { color: blue; } </style> <h1>\" > /var/www/html/index.nginx-debian.html; cat /etc/hostname >> /var/www/html/index.nginx-debian.html; echo \"</h1>\" >> /var/www/html/index.nginx-debian.html; ')]",
        "linuxIPForwarding": "sed -i -e '/^\\(net.ipv4.ip_forward=\\).*/{s//\\11/;:a;n;ba;q}' -e '$anet.ipv4.ip_forward=1' /etc/sysctl.conf; sysctl -p",
        "linuxCommand": "[concat( 'sleep 1m; ',  variables('linuxUpdate'),  variables('linuxNgixCommand') )]",
        "linuxCommandNVA": "[concat( 'sleep 1m; ',  variables('linuxUpdate'),  variables('linuxNgixCommand'), variables('linuxIPForwarding'))]",
        "ubuntu": {
            "publisher": "canonical",
            "offer": "ubuntu-24_04-lts",
            "sku": "server",
            "version": "latest"
        },
        "nvaArray": [
            {
                "location": "[variables('location2')]",
                "vmName": "[variables('nvaName')]",
                "vmSize": "[variables('nvaVMSize')]",
                "publisher": "[variables('ubuntu').publisher]",
                "offer": "[variables('ubuntu').offer]",
                "sku": "[variables('ubuntu').sku]",
                "version": "[variables('ubuntu').version]",
                "vnetName": "[variables('vnet2').name]",
                "nicExternalName": "[concat(variables('nvaName'),'-nic-external')]",
                "nicInternalName": "[concat(variables('nvaName'),'-nic-internal')]",
                "nicPubIPName": "[concat(variables('nvaName'),'-pubIP')]",
                "nicExternalSubnetName": "[variables('vnet2').subnetNvaExternal]",
                "nicInternalSubnetName": "[variables('vnet2').subnetNvaInternal]",
                "nicExternalPrivateAddress": "[variables('nvaExternalPrivIP')]",
                "nicInternalPrivateAddress": "[variables('nvaInternalPrivIP')]",
                "nicIPForwarding": true,
                "nicAcceleratedNetworking": false,
                "nsgExternalName": "[variables('nsgNvaExternal')]",
                "nsgInternalName": "[variables('nsgNvaInternal')]",
                "scriptCommand": ""
            }
        ],
        "nvaCount": "[length(variables('nvaArray'))]",
        "vmSize": "[parameters('vmSize')]",
        "storageAccountType": "[parameters('storageAccountType')]",
        "vm1Name": "vm1",
        "vm2Name": "vm2",
        "vmArray": [
            {
                "deployment": true,
                "location": "[variables('location1')]",
                "vmName": "[variables('vm1Name')]",
                "vmSize": "[variables('vmSize')]",
                "publisher": "[variables('ubuntu').publisher]",
                "offer": "[variables('ubuntu').offer]",
                "sku": "[variables('ubuntu').sku]",
                "version": "[variables('ubuntu').version]",
                "vnetName": "[variables('vnet1').name]",
                "subnetName": "[variables('vnet1').subnetApp]",
                "nicName": "[concat(variables('vm1Name'), '-nic')]",
                "publicIPAddressName": "[concat(variables('vm1Name'), '-pubIP')]",
                "nsgName": "[concat(variables('vm1Name'),'-nsg')]",
                "enableIPForwarding": false,
                "acceleratedNetworking": false,
                "scriptCommand": "sudo apt-get update && sudo apt-get -y install nginx && sudo systemctl enable nginx && sudo systemctl start nginx"
            },
            {
                "deployment": true,
                "location": "[variables('location2')]",
                "vmName": "[variables('vm2Name')]",
                "vmSize": "[variables('vmSize')]",
                "publisher": "[variables('ubuntu').publisher]",
                "offer": "[variables('ubuntu').offer]",
                "sku": "[variables('ubuntu').sku]",
                "version": "[variables('ubuntu').version]",
                "vnetName": "[variables('vnet2').name]",
                "subnetName": "[variables('vnet2').subnetApp]",
                "nicName": "[concat(variables('vm2Name'), '-nic')]",
                "publicIPAddressName": "[concat(variables('vm2Name'), '-pubIP')]",
                "nsgName": "[concat(variables('vm2Name'),'-nsg')]",
                "enableIPForwarding": false,
                "acceleratedNetworking": false,
                "scriptCommand": "sudo apt-get update && sudo apt-get -y install nginx && sudo systemctl enable nginx && sudo systemctl start nginx"
            }
        ],
        "vmCount": "[length(variables('vmArray'))]"
    },
    "resources": [
        {
            "type": "Microsoft.Network/virtualNetworks",
            "name": "[variables('vnet1').name]",
            "apiVersion": "2025-07-01",
            "location": "[variables('vnet1').location]",
            "dependsOn": [],
            "properties": {
                "addressSpace": {
                    "addressPrefixes": [
                        "[variables('vnet1').addressSpace]"
                    ]
                },
                "subnets": [
                    {
                        "name": "[variables('vnet1').subnetApp]",
                        "properties": {
                            "addressPrefix": "[variables('vnet1').subnetAppPrefix]"
                        }
                    },
                    {
                        "name": "[variables('vnet1').GatewaySubnet]",
                        "properties": {
                            "addressPrefix": "[variables('vnet1').GatewaySubnetPrefix]"
                        }
                    }
                ]
            }
        },
        {
            "type": "Microsoft.Network/virtualNetworks",
            "name": "[variables('vnet2').name]",
            "apiVersion": "2025-07-01",
            "location": "[variables('vnet2').location]",
            "dependsOn": [],
            "properties": {
                "addressSpace": {
                    "addressPrefixes": [
                        "[variables('vnet2').addressSpace]"
                    ]
                },
                "subnets": [
                    {
                        "name": "[variables('vnet2').subnetApp]",
                        "properties": {
                            "addressPrefix": "[variables('vnet2').subnetAppPrefix]"
                        }
                    },
                    {
                        "name": "[variables('vnet2').subnetNvaExternal]",
                        "properties": {
                            "addressPrefix": "[variables('vnet2').subnetNvaExternalPrefix]"
                        }
                    },
                    {
                        "name": "[variables('vnet2').subnetNvaInternal]",
                        "properties": {
                            "addressPrefix": "[variables('vnet2').subnetNvaInternalPrefix]"
                        }
                    }
                ]
            }
        },
        {
            "type": "Microsoft.Network/networkSecurityGroups",
            "name": "[variables('nsgSubnet')]",
            "apiVersion": "2025-07-01",
            "location": "[variables('vnet2').location]",
            "comments": "Subnet-level NSG for vnet2 - allows private transit traffic",
            "properties": {
                "securityRules": [
                    {
                        "name": "Allow-Private-Inbound",
                        "properties": {
                            "description": "Allow all inbound traffic between private networks (inter-vnet via NVA)",
                            "protocol": "*",
                            "sourcePortRange": "*",
                            "destinationPortRange": "*",
                            "sourceAddressPrefix": "10.0.0.0/8",
                            "destinationAddressPrefix": "10.0.0.0/8",
                            "access": "Allow",
                            "priority": 100,
                            "direction": "Inbound"
                        }
                    },
                    {
                        "name": "Allow-Private-Outbound",
                        "properties": {
                            "description": "Allow all outbound traffic between private networks",
                            "protocol": "*",
                            "sourcePortRange": "*",
                            "destinationPortRange": "*",
                            "sourceAddressPrefix": "10.0.0.0/8",
                            "destinationAddressPrefix": "10.0.0.0/8",
                            "access": "Allow",
                            "priority": 100,
                            "direction": "Outbound"
                        }
                    }
                ]
            }
        },
        {
            "type": "Microsoft.Network/routeTables",
            "name": "[variables('RTnva')]",
            "apiVersion": "2025-07-01",
            "location": "[variables('vnet2').location]",
            "properties": {
                "disableBgpRoutePropagation": false,
                "routes": [
                    {
                        "name": "to-nva",
                        "properties": {
                            "addressPrefix": "[variables('vnet1').addressSpace]",
                            "nextHopType": "VirtualAppliance",
                            "nextHopIpAddress": "[variables('nvaInternalPrivIP')]"
                        }
                    }
                ]
            }
        },
        {
            "type": "Microsoft.Network/publicIPAddresses",
            "name": "[variables('gatewayPublicIP1Name')]",
            "apiVersion": "2025-07-01",
            "comments": "public IP of the VPN Gateway1-instance 0",
            "location": "[variables('location1')]",
            "zones": [ "1", "2", "3" ],
            "sku": {
                "name": "Standard",
                "tier": "Regional"
            },
            "properties": {
                "publicIPAllocationMethod": "Static"
            }
        },
        {
            "type": "Microsoft.Network/publicIPAddresses",
            "name": "[variables('gatewayPublicIP2Name')]",
            "apiVersion": "2025-07-01",
            "comments": "public IP of the VPN Gateway1-instance 1",
            "location": "[variables('location1')]",
            "zones": [ "1", "2", "3" ],
            "sku": {
                "name": "Standard",
                "tier": "Regional"
            },
            "properties": {
                "publicIPAllocationMethod": "Static"
            }
        },
        {
            "type": "Microsoft.Network/virtualNetworkGateways",
            "name": "[variables('gatewayName')]",
            "apiVersion": "2025-07-01",
            "location": "[variables('location1')]",
            "dependsOn": [
                "[resourceId('Microsoft.Network/publicIPAddresses', variables('gatewayPublicIP1Name'))]",
                "[resourceId('Microsoft.Network/publicIPAddresses', variables('gatewayPublicIP2Name'))]",
                "[resourceId('Microsoft.Network/virtualNetworks', variables('vnet1').name)]"
            ],
            "properties": {
                "ipConfigurations": [
                    {
                        "properties": {
                            "privateIPAllocationMethod": "Dynamic",
                            "subnet": {
                                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets',variables('vnet1').name,'GatewaySubnet') ]"
                            },
                            "publicIPAddress": {
                                "id": "[resourceId('Microsoft.Network/publicIPAddresses',variables('gatewayPublicIP1Name'))]"
                            }
                        },
                        "name": "gwConfig1"
                    },
                    {
                        "properties": {
                            "privateIPAllocationMethod": "Dynamic",
                            "subnet": {
                                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets',variables('vnet1').name,'GatewaySubnet') ]"
                            },
                            "publicIPAddress": {
                                "id": "[resourceId('Microsoft.Network/publicIPAddresses',variables('gatewayPublicIP2Name'))]"
                            }
                        },
                        "name": "gwConfig2"
                    }
                ],
                "sku": {
                    "name": "[parameters('gatewaySku')]",
                    "tier": "[parameters('gatewaySku')]"
                },
                "gatewayType": "Vpn",
                "vpnType": "RouteBased",
                "enableBgp": true,
                "activeActive": true,
                "vpnGatewayGeneration": "Generation2",
                "bgpSettings": {
                    "asn": "[variables('asnGtw1')]"
                }
            }
        },
        {
            "type": "Microsoft.Network/networkSecurityGroups",
            "name": "[variables('nvaArray')[copyIndex()].nsgExternalName]",
            "apiVersion": "2025-07-01",
            "location": "[variables('vnet2').location]",
            "comments": "NSG for NVA external NIC - allows SSH, IKE, ESP for IPsec",
            "copy": {
                "name": "nsgExternalCopy",
                "count": "[variables('nvaCount')]"
            },
            "properties": {
                "securityRules": [
                    {
                        "name": "UDP-Rule1-IKE",
                        "properties": {
                            "description": "Allow UDP for IKE",
                            "protocol": "Udp",
                            "sourcePortRange": "*",
                            "destinationPortRange": "500",
                            "sourceAddressPrefix": "*",
                            "destinationAddressPrefix": "*",
                            "access": "Allow",
                            "priority": 110,
                            "direction": "Inbound"
                        }
                    },
                    {
                        "name": "UDP-Rule2-IKE",
                        "properties": {
                            "description": "Allow UDP for IKE NAT-T",
                            "protocol": "Udp",
                            "sourcePortRange": "*",
                            "destinationPortRange": "4500",
                            "sourceAddressPrefix": "*",
                            "destinationAddressPrefix": "*",
                            "access": "Allow",
                            "priority": 120,
                            "direction": "Inbound"
                        }
                    },
                    {
                        "name": "ESP-allow",
                        "properties": {
                            "description": "Allow ESP",
                            "protocol": "Esp",
                            "sourcePortRange": "*",
                            "destinationPortRange": "*",
                            "sourceAddressPrefix": "*",
                            "destinationAddressPrefix": "*",
                            "access": "Allow",
                            "priority": 130,
                            "direction": "Inbound"
                        }
                    },
                    {
                        "name": "SSH-rule",
                        "properties": {
                            "description": "allow SSH",
                            "protocol": "Tcp",
                            "sourcePortRange": "*",
                            "destinationPortRange": "22",
                            "sourceAddressPrefix": "*",
                            "destinationAddressPrefix": "VirtualNetwork",
                            "access": "Allow",
                            "priority": 500,
                            "direction": "Inbound"
                        }
                    }
                ]
            }
        },
        {
            "type": "Microsoft.Network/networkSecurityGroups",
            "name": "[variables('nvaArray')[copyIndex()].nsgInternalName]",
            "apiVersion": "2025-07-01",
            "location": "[variables('vnet2').location]",
            "comments": "NSG for NVA internal NIC - allows VNet transit traffic",
            "copy": {
                "name": "nsgInternalCopy",
                "count": "[variables('nvaCount')]"
            },
            "properties": {
                "securityRules": [
                    {
                        "name": "Allow-VNet-Inbound",
                        "properties": {
                            "description": "Allow all inbound traffic from VNet (transit via NVA)",
                            "protocol": "*",
                            "sourcePortRange": "*",
                            "destinationPortRange": "*",
                            "sourceAddressPrefix": "VirtualNetwork",
                            "destinationAddressPrefix": "*",
                            "access": "Allow",
                            "priority": 100,
                            "direction": "Inbound"
                        }
                    },
                    {
                        "name": "Allow-Private-Inbound",
                        "properties": {
                            "description": "Allow all inbound from private ranges (decrypted IPsec traffic)",
                            "protocol": "*",
                            "sourcePortRange": "*",
                            "destinationPortRange": "*",
                            "sourceAddressPrefix": "10.0.0.0/8",
                            "destinationAddressPrefix": "10.0.0.0/8",
                            "access": "Allow",
                            "priority": 110,
                            "direction": "Inbound"
                        }
                    },
                    {
                        "name": "Allow-Private-Outbound",
                        "properties": {
                            "description": "Allow forwarded traffic out (transit via NVA)",
                            "protocol": "*",
                            "sourcePortRange": "*",
                            "destinationPortRange": "*",
                            "sourceAddressPrefix": "10.0.0.0/8",
                            "destinationAddressPrefix": "10.0.0.0/8",
                            "access": "Allow",
                            "priority": 100,
                            "direction": "Outbound"
                        }
                    }
                ]
            }
        },
        {
            "type": "Microsoft.Network/publicIPAddresses",
            "name": "[variables('nvaArray')[copyIndex()].nicPubIPName]",
            "apiVersion": "2025-07-01",
            "location": "[variables('nvaArray')[copyIndex()].location]",
            "comments": "Public IP for NVA (management + IPsec endpoint)",
            "sku": {
                "name": "Standard",
                "tier": "Regional"
            },
            "properties": {
                "publicIPAllocationMethod": "Static"
            },
            "copy": {
                "name": "publicIpCopy",
                "count": "[variables('nvaCount')]"
            }
        },
        {
            "type": "Microsoft.Network/networkInterfaces",
            "name": "[variables('nvaArray')[copyIndex()].nicExternalName]",
            "apiVersion": "2025-07-01",
            "location": "[variables('nvaArray')[copyIndex()].location]",
            "comments": "NVA external NIC - SSH and IPsec endpoint with public IP",
            "dependsOn": [
                "[resourceId('Microsoft.Network/virtualNetworks', variables('nvaArray')[copyIndex()].vnetName)]",
                "[resourceId('Microsoft.Network/publicIPAddresses', variables('nvaArray')[copyIndex()].nicPubIPName)]",
                "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nvaArray')[copyIndex()].nsgExternalName)]"
            ],
            "properties": {
                "enableIPForwarding": "[variables('nvaArray')[copyIndex()].nicIPForwarding]",
                "enableAcceleratedNetworking": "[variables('nvaArray')[copyIndex()].nicAcceleratedNetworking]",
                "ipConfigurations": [
                    {
                        "name": "ipconfig1",
                        "properties": {
                            "privateIPAllocationMethod": "Static",
                            "privateIPAddress": "[variables('nvaArray')[copyIndex()].nicExternalPrivateAddress]",
                            "publicIPAddress": {
                                "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('nvaArray')[copyIndex()].nicPubIPName)]"
                            },
                            "subnet": {
                                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('nvaArray')[copyIndex()].vnetName, variables('nvaArray')[copyIndex()].nicExternalSubnetName)]"
                            }
                        }
                    }
                ],
                "networkSecurityGroup": {
                    "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nvaArray')[copyIndex()].nsgExternalName)]"
                }
            },
            "copy": {
                "name": "nicExternalCopy",
                "count": "[variables('nvaCount')]"
            }
        },
        {
            "type": "Microsoft.Network/networkInterfaces",
            "name": "[variables('nvaArray')[copyIndex()].nicInternalName]",
            "apiVersion": "2025-07-01",
            "location": "[variables('nvaArray')[copyIndex()].location]",
            "comments": "NVA internal NIC - transit traffic to/from VM2 (no public IP)",
            "dependsOn": [
                "[resourceId('Microsoft.Network/virtualNetworks', variables('nvaArray')[copyIndex()].vnetName)]",
                "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nvaArray')[copyIndex()].nsgInternalName)]"
            ],
            "properties": {
                "enableIPForwarding": "[variables('nvaArray')[copyIndex()].nicIPForwarding]",
                "enableAcceleratedNetworking": "[variables('nvaArray')[copyIndex()].nicAcceleratedNetworking]",
                "ipConfigurations": [
                    {
                        "name": "ipconfig1",
                        "properties": {
                            "privateIPAllocationMethod": "Static",
                            "privateIPAddress": "[variables('nvaArray')[copyIndex()].nicInternalPrivateAddress]",
                            "subnet": {
                                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('nvaArray')[copyIndex()].vnetName, variables('nvaArray')[copyIndex()].nicInternalSubnetName)]"
                            }
                        }
                    }
                ],
                "networkSecurityGroup": {
                    "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nvaArray')[copyIndex()].nsgInternalName)]"
                }
            },
            "copy": {
                "name": "nicInternalCopy",
                "count": "[variables('nvaCount')]"
            }
        },
        {
            "type": "Microsoft.Compute/virtualMachines",
            "name": "[variables('nvaArray')[copyIndex()].vmName]",
            "apiVersion": "2025-11-01",
            "location": "[variables('nvaArray')[copyIndex()].location]",
            "dependsOn": [
                "[resourceId('Microsoft.Network/networkInterfaces', variables('nvaArray')[copyIndex()].nicExternalName)]",
                "[resourceId('Microsoft.Network/networkInterfaces', variables('nvaArray')[copyIndex()].nicInternalName)]"
            ],
            "properties": {
                "hardwareProfile": {
                    "vmSize": "[variables('nvaArray')[copyIndex()].vmSize]"
                },
                "osProfile": {
                    "computerName": "[variables('nvaArray')[copyIndex()].vmName]",
                    "adminUsername": "[parameters('adminUsername')]",
                    "adminPassword": "[parameters('adminPassword')]"
                },
                "storageProfile": {
                    "imageReference": {
                        "publisher": "[variables('nvaArray')[copyIndex()].publisher]",
                        "offer": "[variables('nvaArray')[copyIndex()].offer]",
                        "sku": "[variables('nvaArray')[copyIndex()].sku]",
                        "version": "[variables('nvaArray')[copyIndex()].version]"
                    },
                    "osDisk": {
                        "createOption": "FromImage",
                        "name": "[concat(variables('nvaArray')[copyIndex()].vmName,'-OSdisk')]",
                        "caching": "ReadWrite",
                        "deleteOption": "Delete"
                    }
                },
                "networkProfile": {
                    "networkInterfaces": [
                        {
                            "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('nvaArray')[copyIndex()].nicExternalName)]",
                            "properties": {
                                "deleteOption": "Delete",
                                "primary": true
                            }
                        },
                        {
                            "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('nvaArray')[copyIndex()].nicInternalName)]",
                            "properties": {
                                "deleteOption": "Delete",
                                "primary": false
                            }
                        }
                    ]
                }
            },
            "copy": {
                "name": "nvaCopy",
                "count": "[variables('nvaCount')]"
            }
        },
