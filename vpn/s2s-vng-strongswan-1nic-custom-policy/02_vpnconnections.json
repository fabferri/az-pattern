{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location1": {
            "type": "string",
            "defaultValue": "uksouth",
            "metadata": {
                "description": "Azure region"
            }
        },
        "location2": {
            "type": "string",
            "defaultValue": "uksouth",
            "metadata": {
                "description": "Azure region"
            }
        },
        "gatewayName": {
            "type": "string",
            "defaultValue": "gw",
            "metadata": {
                "description": "Arbitrary name for the new gateway1"
            }
        },
        "localGatewayName1": {
            "type": "string",
            "defaultValue": "localGateway1",
            "metadata": {
                "description": "Arbitrary name for gateway resource representing VPN gateway1"
            }
        },
        "localGatewayName2": {
            "type": "string",
            "defaultValue": "localGateway2",
            "metadata": {
                "description": "Arbitrary name for gateway resource representing VPN gateway1"
            }
        },
        "asnGtw2": {
            "type": "int",
            "defaultValue": 65020,
            "metadata": {
                "description": "BGP Autonomous System Number of the remote VNet"
            }
        },
        "connectionName1": {
            "type": "string",
            "defaultValue": "conn1-to-nva",
            "metadata": {
                "description": "Arbitrary name for the new connection between Azure VNet and other network"
            }
        },
        "connectionName2": {
            "type": "string",
            "defaultValue": "conn2-to-nva",
            "metadata": {
                "description": "Arbitrary name for the new connection between Azure VNet and other network"
            }
        },
        "sharedKey": {
            "type": "string",
            "defaultValue": "[format('secr{0}', uniqueString(resourceGroup().id, subscription().subscriptionId))]",
            "metadata": {
                "description": "Shared key (PSK) for IPSec tunnel"
            }
        },
        "nvaName": {
            "type": "string",
            "defaultValue": "nva",
            "metadata": {
                "description": "NVA name"
            }
        }
    },
    "variables": {
        "location1": "[parameters('location1')]",
        "gatewayName": "[parameters('gatewayName')]",

        "localGatewayName1": "[parameters('localGatewayName1')]",
        "localGatewayName2": "[parameters('localGatewayName2')]",

        "asnGtw2": "[parameters('asnGtw2')]",
        "connectionName1": "[parameters('connectionName1')]",
        "connectionName2": "[parameters('connectionName2')]",
        "nvaName": "[parameters('nvaName')]",
        "nvaPubIPName": "[concat(variables('nvaName'),'-pubIP')]",
        "nvaBGPIP1": "192.168.0.1",
        "nvaBGPIP2": "192.168.0.2"
    },
    "resources": [
        {
            "type": "Microsoft.Network/localNetworkGateways",
            "name": "[variables('localGatewayName1')]",
            "apiVersion": "2025-07-01",
            "comments": "public IP of remote IPSec peer",
            "location": "[variables('location1')]",
            "dependsOn": [],
            "properties": {
                "gatewayIpAddress": "[reference(resourceId('Microsoft.Network/publicIPAddresses',variables('nvaPubIPName')),'2025-07-01').ipAddress]",
                "bgpSettings": {
                    "asn": "[variables('asnGtw2')]",
                    "bgpPeeringAddress": "[variables('nvaBGPIP1')]",
                    "peerWeight": 0
                }
            }
        },
        {
            "type": "Microsoft.Network/localNetworkGateways",
            "name": "[variables('localGatewayName2')]",
            "apiVersion": "2025-07-01",
            "comments": "public IP of remote IPSec peer",
            "location": "[variables('location1')]",
            "dependsOn": [],
            "properties": {
                "gatewayIpAddress": "[reference(resourceId('Microsoft.Network/publicIPAddresses',variables('nvaPubIPName')),'2025-07-01').ipAddress]",
                "bgpSettings": {
                    "asn": "[variables('asnGtw2')]",
                    "bgpPeeringAddress": "[variables('nvaBGPIP2')]",
                    "peerWeight": 0
                }
            }
        },
        {
            "type": "Microsoft.Network/connections",
            "name": "[variables('connectionName1')]",
            "apiVersion": "2025-07-01",
            "comments": "VPN connection between [Gateway1] and [Gateway2-pubIP1] with custom IPsec/IKE policy (GCMAES256)",
            "location": "[variables('location1')]",
            "dependsOn": [
                "[resourceId('Microsoft.Network/localNetworkGateways', variables('localGatewayName1'))]"
            ],
            "properties": {
                "virtualNetworkGateway1": {
                    "id": "[resourceId('Microsoft.Network/virtualNetworkGateways',variables('gatewayName'))]"
                },
                "localNetworkGateway2": {
                    "id": "[resourceId('Microsoft.Network/localNetworkGateways', variables('localGatewayName1'))]"
                },
                "connectionType": "IPsec",
                "routingWeight": 0,
                "sharedKey": "[parameters('sharedKey')]",
                "enableBGP": true,
                "ipsecPolicies": [
                    {
                        "saLifeTimeSeconds": 3600,
                        "saDataSizeKilobytes": 102400000,
                        "ipsecEncryption": "GCMAES256",
                        "ipsecIntegrity": "GCMAES256",
                        "ikeEncryption": "GCMAES256",
                        "ikeIntegrity": "SHA256",
                        "dhGroup": "DHGroup14",
                        "pfsGroup": "PFS2048"
                    }
                ],
                "usePolicyBasedTrafficSelectors": false
            }
        },
        {
            "type": "Microsoft.Network/connections",
            "name": "[variables('connectionName2')]",
            "apiVersion": "2025-07-01",
            "comments": "VPN connection between [Gateway1] and [Gateway2-pubIP2] with custom IPsec/IKE policy (GCMAES256)",
            "location": "[variables('location1')]",
            "dependsOn": [
                "[resourceId('Microsoft.Network/localNetworkGateways', variables('localGatewayName2'))]"
            ],
            "properties": {
                "virtualNetworkGateway1": {
                    "id": "[resourceId('Microsoft.Network/virtualNetworkGateways',variables('gatewayName'))]"
                },
                "localNetworkGateway2": {
                    "id": "[resourceId('Microsoft.Network/localNetworkGateways', variables('localGatewayName2'))]"
                },
                "connectionType": "IPsec",
                "routingWeight": 0,
                "sharedKey": "[parameters('sharedKey')]",
                "enableBGP": true,
                "ipsecPolicies": [
                    {
                        "saLifeTimeSeconds": 3600,
                        "saDataSizeKilobytes": 102400000,
                        "ipsecEncryption": "GCMAES256",
                        "ipsecIntegrity": "GCMAES256",
                        "ikeEncryption": "GCMAES256",
                        "ikeIntegrity": "SHA256",
                        "dhGroup": "DHGroup14",
                        "pfsGroup": "PFS2048"
                    }
                ],
                "usePolicyBasedTrafficSelectors": false
            }
        }
    ],
    "outputs": {
        "sharedSecret_conn1": {
            "type": "string",
            "value": "[parameters('sharedKey')]"
        },
        "sharedSecret_conn2": {
            "type": "string",
            "value": "[parameters('sharedKey')]"
        }
    }
}